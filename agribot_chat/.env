# agribot_chat：RAG 知识库问答独立模块
# 可与 agribot_admin 共用 .env，或复制相关变量到此文件

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=mildoc
MILVUS_COLLECTION=mildoc_collection
MILVUS_VECTOR_DIM=768

# LLM
LLM_MODEL_NAME=qwen-plus
LLM_API_KEY=REDACTED_API_KEY
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding
LLM_EMBEDDING_MODEL_NAME=text-embedding-v4
LLM_EMBEDDING_API_KEY=REDACTED_API_KEY
LLM_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Rerank（可选）
RERANK_PROVIDER=dashscope
RERANK_API_KEY=REDACTED_API_KEY
RERANK_MODEL_NAME=qwen3-rerank
RERANK_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# 服务启动（chat_app.py）
AGRIBOT_CHAT_HOST=0.0.0.0
AGRIBOT_CHAT_PORT=8890
AGRIBOT_CHAT_DEBUG=false
# AGRIBOT_CHAT_LOG=/export/workspace/rag/agribot_chat/agribot_chat.log

# Chat 登录默认账号（用于 agribot_chat.chat_app）
CHAT_USERNAME=admin
CHAT_PASSWORD=admin
AGRIBOT_CHAT_SECRET_KEY=agribot-chat-secret-key


# MySQL 数据库配置（用于 agribot_chat.routers.database）
MYSQL_HOST=140.143.192.129
MYSQL_USER=wuziyang
MYSQL_PASSWORD=REDACTED_MYSQL_PASSWORD
MYSQL_DATABASE=oceanhub
MYSQL_PORT=3306
MYSQL_CHARSET=utf8mb4

# MongoDB 数据库配置（用于 agribot_chat.routers.database）
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=agribot
MONGO_PASSWORD=agribot123
MONGO_DATABASE=agribot


# 163邮箱 SMTP配置
SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=iswuziyang@163.com
SMTP_PASSWORD=REDACTED_SMTP_PASSWORD
FROM_EMAIL=iswuziyang@163.com
# Neo4j 知识图谱（Graph RAG）
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=REDACTED_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j
