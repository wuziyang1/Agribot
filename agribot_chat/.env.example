# agribot_chat：RAG 知识库问答独立模块
# 可与 agribot_admin 共用 .env，或复制相关变量到此文件

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_COLLECTION=mildoc_collection
MILVUS_VECTOR_DIM=1536

# LLM
LLM_MODEL_NAME=
LLM_API_KEY=
LLM_BASE_URL=

# Embedding
LLM_EMBEDDING_MODEL_NAME=
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_BASE_URL=

# Rerank（可选）
# RERANK_PROVIDER=dashscope
# RERANK_API_KEY=
# RERANK_MODEL_NAME=gte-rerank-v2
# RERANK_ENDPOINT=

# 服务启动（chat_app.py）
AGRIBOT_CHAT_HOST=0.0.0.0
AGRIBOT_CHAT_PORT=8890
AGRIBOT_CHAT_DEBUG=False
# AGRIBOT_CHAT_LOG=/export/workspace/rag/agribot_chat/agribot_chat.log

# Chat 登录
CHAT_USERNAME=admin
CHAT_PASSWORD=
AGRIBOT_CHAT_SECRET_KEY=

# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_PORT=3306
MYSQL_CHARSET=utf8mb4

# MongoDB 数据库配置
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DATABASE=agribot

# SMTP 邮箱配置
SMTP_SERVER=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=

# Neo4j 知识图谱（Graph RAG）
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
