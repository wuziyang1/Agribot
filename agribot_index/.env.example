# minio
##172.31.154.203:9000
ENDPOINT={ENDPOINT}
ACCESS_KEY={ACCESS_KEY}
SECRET_KEY={SECRET_KEY}
MINIO_BUCKET=agribot

# local minio
#ENDPOINT=127.0.0.1:9000
#ACCESS_KEY=minioadmin
#SECRET_KEY=minioadmin
#MINIO_BUCKET=agribot

# milvus
MILVUS_HOST={MILVUS_HOST}
MILVUS_PORT=19530
MILVUS_USER=lvlian
MILVUS_PASSWORD={MILVUS_PASSWORD}
MILVUS_DATABASE=agribot
MILVUS_COLLECTION=agribot_collection
MILVUS_INDEX_NAME=mildoc_index
MILVUS_VECTOR_DIM=1024

# Neo4j 知识图谱（Graph RAG）
# 是否在上传时自动进行知识图谱构建（命名实体识别与关系抽取）
# true = 启用；false = 关闭（仅做向量索引）
ENABLE_GRAPH_RAG=false

# bailian embedding llm (deprecated)
#OPENAI_API_KEY={OPENAI_API_KEY}
#OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#ENBEDDING_MODEL=text-embedding-v4

# siliconflow embedding llm
OPENAI_API_KEY={OPENAI_API_KEY}
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
ENBEDDING_MODEL=BAAI/bge-m3


# MinerU服务器配置
#MINERU_SERVER_URL=http://127.0.0.1:30000

# 扫描件 PDF OCR（DeepSeek-OCR）
# 启用扫描件 OCR（当 PDFParser/markitdown 提取不到文本时会尝试 OCR）
ENABLE_PDF_OCR=true
# DeepSeek-OCR 使用 OpenAI-compatible 的 chat.completions
# 例如硅基流动：
# OCR_BASE_URL=https://api.siliconflow.cn/v1
# OCR_API_KEY={OPENAI_API_KEY}
# 或者 DeepInfra：
# OCR_BASE_URL=https://api.deepinfra.com/v1/openai
# OCR_API_KEY=your_deepinfra_token
OCR_BASE_URL=
OCR_API_KEY=
OCR_MODEL_NAME=deepseek-ai/DeepSeek-OCR
# 渲染/性能参数
OCR_PDF_DPI=200
OCR_MAX_PAGES=20
OCR_TIMEOUT_S=120