# mildoc_chat：RAG 知识库问答独立模块
# 可与 mildoc_admin 共用 .env，或复制相关变量到此文件

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=mildoc
MILVUS_COLLECTION=mildoc_collection
MILVUS_VECTOR_DIM=768

# LLM
LLM_MODEL_NAME=qwen-plus
LLM_API_KEY=REDACTED_API_KEY
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding
LLM_EMBEDDING_MODEL_NAME=text-embedding-v4
LLM_EMBEDDING_API_KEY=REDACTED_API_KEY
LLM_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Rerank（可选）
RERANK_PROVIDER=dashscope
RERANK_API_KEY=REDACTED_API_KEY
RERANK_MODEL_NAME=qwen3-rerank
RERANK_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# 服务启动（chat_app.py）
MILDOC_CHAT_HOST=0.0.0.0
MILDOC_CHAT_PORT=8890
MILDOC_CHAT_DEBUG=false
# MILDOC_CHAT_LOG=/export/workspace/rag/mildoc_chat/mildoc_chat.log

# Chat 登录默认账号（用于 mildoc_chat.chat_app）
CHAT_USERNAME=admin
CHAT_PASSWORD=admin
MILDOC_CHAT_SECRET_KEY=mildoc-chat-secret-key


# MySQL 数据库配置（用于 mildoc_chat.routers.database）
MYSQL_HOST=140.143.192.129
MYSQL_USER=wuziyang
MYSQL_PASSWORD=REDACTED_MYSQL_PASSWORD
MYSQL_DATABASE=oceanhub
MYSQL_PORT=3306
MYSQL_CHARSET=utf8mb4


# 163邮箱 SMTP配置
SMTP_SERVER=smtp.163.com
SMTP_PORT=25
SMTP_USERNAME=iswuziyang@163.com
SMTP_PASSWORD=REDACTED_SMTP_PASSWORD
FROM_EMAIL=iswuziyang@163.com