# mildoc_chat：RAG 知识库问答独立模块
# 可与 mildoc_admin 共用 .env，或复制相关变量到此文件

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_COLLECTION=mildoc_collection
MILVUS_VECTOR_DIM=1536

# LLM
LLM_MODEL_NAME=
LLM_API_KEY=
LLM_BASE_URL=

# Embedding
LLM_EMBEDDING_MODEL_NAME=
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_BASE_URL=

# Rerank（可选）
# RERANK_PROVIDER=dashscope
# RERANK_API_KEY=
# RERANK_MODEL_NAME=gte-rerank-v2
# RERANK_ENDPOINT=

# 服务启动（chat_app.py）
MILDOC_CHAT_HOST=0.0.0.0
MILDOC_CHAT_PORT=8890
MILDOC_CHAT_DEBUG=False
# MILDOC_CHAT_LOG=/export/workspace/rag/mildoc_chat/mildoc_chat.log
